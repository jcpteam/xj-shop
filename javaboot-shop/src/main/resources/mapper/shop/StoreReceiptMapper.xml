<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreReceiptMapper">

    <resultMap type="com.javaboot.shop.vo.StoreReceiptVO" id="StoreReceiptResult">
        <result property="receiptId"    column="receipt_id"    />
        <result property="orderIds"    column="order_ids"    />
        <result property="merchantId"    column="merchant_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="code"    column="code"    />
        <result property="payStatus"    column="pay_status"    />
        <result property="amount"    column="amount"    />
        <result property="balance"    column="balance"    />
        <result property="comment"    column="comment"    />
        <result property="voucherPath"    column="voucher_path"    />
        <result property="status"    column="status"    />
        <result property="payType"    column="pay_type"    />
        <result property="creatorName"    column="creator_name"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreReceiptVo">
        select * from store_receipt
    </sql>

    <select id="selectStoreReceiptList" parameterType="com.javaboot.shop.dto.StoreReceiptQueryDTO" resultMap="StoreReceiptResult">
        <include refid="selectStoreReceiptVo"/>
        <where>
            AND status!=0
            <if test="status != null and status !='' "> and status = #{status}</if>
            <if test="orderIds != null and orderIds !='' "> and order_ids = #{orderIds}</if>
            <if test="merchantId != null  and merchantId != ''"> and merchant_id = #{merchantId}</if>
            <if test="deptId != null  and deptId != ''"> and dept_id = #{deptId}</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="payStatus != null  and payStatus != ''"> and pay_status = #{payStatus}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="balance != null "> and balance = #{balance}</if>
            <if test="comment != null  and comment != ''"> and comment = #{comment}</if>
            <if test="voucherPath != null  and voucherPath != ''"> and voucher_path = #{voucherPath}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
            <if test="minAmount !=null">
                AND  amount &gt;=#{minAmount}
            </if>
            <if test="maxAmount !=null">
                AND amount &lt;#{maxAmount}
            </if>
            <if test="merchantName != null and merchantName!='' ">
                AND EXISTS (
                SELECT
                1
                FROM
                store_member s1
                WHERE
                s1.id=merchant_id AND

                s1.nickname like concat('%', #{merchantName}, '%')


                )
            </if>
            <if test="orderIdList !=null and orderIdList.size()>0">
                and
                <foreach item="orderId" collection="orderIdList" open="(" close=")" separator="or">
                    find_in_set( #{orderId}, order_ids )
                </foreach>

            </if>
            <if test="payBeginDate != null and payBeginDate!='' and payEndDate != null and payEndDate!='' ">
                AND pay_status = '1'
                and last_modify_time
                BETWEEN
                DATE_FORMAT(#{payBeginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{payEndDate},'%Y-%m-%d %H:%i:%s')
            </if>
            <if test="receiptBeginDate != null and receiptBeginDate!='' and receiptEndDate != null and receiptEndDate!='' ">
                and create_time
                BETWEEN
                DATE_FORMAT(#{receiptBeginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{receiptEndDate},'%Y-%m-%d %H:%i:%s')
            </if>
        </where>
    </select>

    <select id="selectExportStoreReceiptList" parameterType="com.javaboot.shop.dto.StoreReceiptQueryDTO" resultType="com.javaboot.shop.vo.StoreReceiptVO">
        SELECT
        t2.*, t1.code ordercode, t1.create_time ordercreatetime, t1.delivery_date deliverydate
        FROM
        store_goods_order t1
        JOIN store_receipt t2 ON FIND_IN_SET(t1.order_id, t2.order_ids)
        <where>
            AND t2.status!=0
            <if test="status != null and status !='' "> and t2.status = #{status}</if>
            <if test="orderIds != null and orderIds !='' "> and t2.order_ids = #{orderIds}</if>
            <if test="merchantId != null  and merchantId != ''"> and t2.merchant_id = #{merchantId}</if>
            <if test="deptId != null  and deptId != ''"> and t2.dept_id = #{deptId}</if>
            <if test="code != null  and code != ''"> and t2.code = #{code}</if>
            <if test="payStatus != null  and payStatus != ''"> and t2.pay_status = #{payStatus}</if>
            <if test="amount != null "> and t2.amount = #{amount}</if>
            <if test="balance != null "> and t2.balance = #{balance}</if>
            <if test="comment != null  and comment != ''"> and t2.comment = #{comment}</if>
            <if test="voucherPath != null  and voucherPath != ''"> and t2.voucher_path = #{voucherPath}</if>
            <if test="lastModifyTime != null "> and t2.last_modify_time = #{lastModifyTime}</if>
            <if test="minAmount !=null">
                AND  t2.amount &gt;=#{minAmount}
            </if>
            <if test="maxAmount !=null">
                AND t2.amount &lt;#{maxAmount}
            </if>
            <if test="merchantName != null and merchantName!='' ">
                AND EXISTS (
                SELECT
                1
                FROM
                store_member s1
                WHERE
                s1.id=t2.merchant_id AND
                s1.nickname like concat('%', #{merchantName}, '%')
                )
            </if>
            <if test="payBeginDate != null and payBeginDate!='' and payEndDate != null and payEndDate!='' ">
                AND t2.pay_status = '1'
                and t2.last_modify_time
                BETWEEN
                DATE_FORMAT(#{payBeginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{payEndDate},'%Y-%m-%d %H:%i:%s')
            </if>
            <if test="receiptBeginDate != null and receiptBeginDate!='' and receiptEndDate != null and receiptEndDate!='' ">
                and t2.create_time
                BETWEEN
                DATE_FORMAT(#{receiptBeginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{receiptEndDate},'%Y-%m-%d %H:%i:%s')
            </if>
        </where>
        ORDER  BY t2.last_modify_time desc
        LIMIT 2000
    </select>

    <select id="selectStoreReceiptById" parameterType="Long" resultMap="StoreReceiptResult">
        <include refid="selectStoreReceiptVo"/>
        where receipt_id = #{receiptId}
    </select>

    <insert id="insertStoreReceipt" parameterType="com.javaboot.shop.domain.StoreReceipt" useGeneratedKeys="true" keyProperty="receiptId">
        insert into store_receipt
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderIds != null and orderIds !='' ">order_ids,</if>
            <if test="merchantId != null  and merchantId != ''">merchant_id,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="code != null  and code != ''">code,</if>
            <if test="payStatus != null  and payStatus != ''">pay_status,</if>
            <if test="amount != null ">amount,</if>
            <if test="balance != null ">balance,</if>
            <if test="comment != null  and comment != ''">comment,</if>
            <if test="voucherPath != null  and voucherPath != ''">voucher_path,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderIds != null and orderIds !='' ">#{orderIds},</if>
            <if test="merchantId != null  and merchantId != ''">#{merchantId},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="code != null  and code != ''">#{code},</if>
            <if test="payStatus != null  and payStatus != ''">#{payStatus},</if>
            <if test="amount != null ">#{amount},</if>
            <if test="balance != null ">#{balance},</if>
            <if test="comment != null  and comment != ''">#{comment},</if>
            <if test="voucherPath != null  and voucherPath != ''">#{voucherPath},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
        </trim>
    </insert>

    <update id="updateStoreReceipt" parameterType="com.javaboot.shop.domain.StoreReceipt">
        update store_receipt
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderIds != null and orderIds !='' and orderIds !='' ">order_ids = #{orderIds},</if>
            <if test="merchantId != null  and merchantId != ''">merchant_id = #{merchantId},</if>
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="code != null  and code != ''">code = #{code},</if>
            <if test="payStatus != null  and payStatus != ''">pay_status = #{payStatus},</if>
            <if test="amount != null ">amount = #{amount},</if>
            <if test="balance != null ">balance = #{balance},</if>
            <if test="comment != null  and comment != ''">comment = #{comment},</if>
            <if test="voucherPath != null  and voucherPath != ''">voucher_path = #{voucherPath},</if>
            <if test="status != null  and status != ''">status= #{status},</if>
            <if test="payType != null  and payType != ''">pay_type= #{payType},</if>
            <if test="creatorName != null  and creatorName != ''">creator_name= #{creatorName},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where receipt_id = #{receiptId}
    </update>

    <update id="updateCertificate" parameterType="com.javaboot.shop.domain.StoreReceipt">
        update store_receipt SET voucher_path = NULL, pay_type = NULL ,comment = NULL,
        <if test="payStatus != null  and payStatus != ''">pay_status = #{payStatus},</if>
        creator_name = NULL
        where receipt_id = #{receiptId}
    </update>

    <delete id="deleteStoreReceiptById" parameterType="Long">
        update store_receipt set status=0,last_modify_time = now()  where receipt_id = #{receiptId}
    </delete>

    <delete id="deleteStoreReceiptByIds" parameterType="String">
        update store_receipt set status=0,last_modify_time = now() where receipt_id in
        <foreach item="receiptId" collection="array" open="(" separator="," close=")">
            #{receiptId}
        </foreach>
    </delete>

</mapper>