<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreEarlyWarningMapper">
    
    <resultMap type="StoreEarlyWarning" id="StoreEarlyWarningResult">
        <result property="id"    column="id"    />
        <result property="warningKey"    column="warning_key"    />
        <result property="deptId"    column="dept_id"    />
        <result property="status"    column="status"    />
        <result property="comment"    column="comment"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreEarlyWarningVo">
        select id, warning_key, dept_id, status, comment, create_time, last_modify_time from store_early_warning
    </sql>

    <select id="selectStoreEarlyWarningList" parameterType="StoreEarlyWarning" resultMap="StoreEarlyWarningResult">
        <include refid="selectStoreEarlyWarningVo"/>
        <where>  
            <if test="warningKey != null  and warningKey != ''"> and warning_key = #{warningKey}</if>
            <if test="deptId != null  and deptId != ''"> and dept_id = #{deptId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="comment != null  and comment != ''"> and comment = #{comment}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
        </where>
    </select>
    
    <select id="selectStoreEarlyWarningById" parameterType="Long" resultMap="StoreEarlyWarningResult">
        <include refid="selectStoreEarlyWarningVo"/>
        where id = #{id}
    </select>

    <insert id="insertStoreEarlyWarning" parameterType="StoreEarlyWarning" useGeneratedKeys="true" keyProperty="id">
        insert into store_early_warning
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="warningKey != null  and warningKey != ''">warning_key,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="comment != null  and comment != ''">comment,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="warningKey != null  and warningKey != ''">#{warningKey},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="comment != null  and comment != ''">#{comment},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreEarlyWarning" parameterType="StoreEarlyWarning">
        update store_early_warning
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="comment != null  and comment != ''">comment = #{comment},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where warning_key = #{warningKey}
    </update>

    <delete id="deleteStoreEarlyWarningById" parameterType="Long">
        delete from store_early_warning where id = #{id}
    </delete>

    <delete id="deleteStoreEarlyWarningByIds" parameterType="String">
        delete from store_early_warning where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getNoOrderCustomerListForWarn" parameterType="java.util.Map" resultType="com.javaboot.shop.domain.StoreMember">
        select sm.* from store_member sm
        join (
            select r.merchant_id from (
              SELECT DISTINCT t1.merchant_id FROM `store_goods_order` t1 where t1.create_time &gt;= #{beforeYestodayStart} and t1.create_time &lt;= #{beforeYestodayEnd}
            ) r
            where r.merchant_id not in (
              SELECT DISTINCT merchant_id FROM `store_goods_order` where create_time &gt;= #{yestodayStart} and create_time &lt;= #{yestodayEnd}
            )
        ) as temp on sm.id = temp.merchant_id
    </select>
    
</mapper>