<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StorePaymentAccountMapper">
    
    <resultMap type="com.javaboot.shop.vo.StorePaymentAccountVO" id="StorePaymentAccountResult">
        <result property="accountId"    column="account_id"    />
        <result property="memberId"    column="member_id"    />
        <result property="billDays"    column="bill_days"    />
        <result property="accountNumber"    column="account_number"    />
        <result property="storeId"    column="store_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="cash"    column="cash"    />
        <result property="status"    column="status"    />
        <result property="rebateAccount"    column="rebate_account"    />
        <result property="bondAccount"    column="bond_account"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStorePaymentAccountVo">
        select * from store_payment_account
    </sql>

    <select id="selectStorePaymentAccountList" parameterType="com.javaboot.shop.dto.StorePaymentAccountQueryDTO" resultMap="StorePaymentAccountResult">
        <include refid="selectStorePaymentAccountVo"/>
        <where>
            AND status !=0
            <if test="memberId != null  and memberId != ''"> and member_id = #{memberId}</if>
            <if test="accountNumber != null  and accountNumber != ''"> and account_number = #{accountNumber}</if>
            <if test="storeId != null  and storeId != ''"> and store_id = #{storeId}</if>
            <if test="deptId != null  and deptId != ''"> and dept_id = #{deptId}</if>
            <if test="cash != null "> and cash = #{cash}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="billDays != null  and billDays != ''"> and bill_days = #{billDays}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
            <if test="searchKey != null and searchKey!='' ">
                 and
                    (
                account_number like concat('%', #{searchKey}, '%')
                    OR
                member_id like concat('%', #{searchKey}, '%')
                    )
             </if>
            <if test="nickName != null and nickName!='' ">
                AND EXISTS (
                SELECT
                1
                FROM
                store_member s1
                WHERE
                s1.id=member_id AND

                s1.nickname like concat('%', #{nickName}, '%')

                )
            </if>
            <if test="memberIdList!=null and memberIdList.size()>0">
                AND status=1
                AND member_id in
                <foreach collection="memberIdList" item="mid" open="(" separator="," close=")">
                    #{mid}
                </foreach>
            </if>
        </where>
    </select>
    
    <select id="selectStorePaymentAccountById" parameterType="String" resultMap="StorePaymentAccountResult">
        <include refid="selectStorePaymentAccountVo"/>
        where account_id = #{accountId}
    </select>
        
    <insert id="insertStorePaymentAccount" parameterType="StorePaymentAccount">
        insert into store_payment_account
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="accountId != null ">account_id,</if>
            <if test="memberId != null  and memberId != ''">member_id,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="accountNumber != null  and accountNumber != ''">account_number,</if>
            <if test="billDays != null  and billDays != ''">bill_days,</if>
            <if test="storeId != null  and storeId != ''">store_id,</if>
            <if test="cash != null ">cash,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="accountId != null ">#{accountId},</if>
            <if test="memberId != null  and memberId != ''">#{memberId},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="accountNumber != null  and accountNumber != ''">#{accountNumber},</if>
            <if test="billDays != null  and billDays != ''">#{billDays},</if>
            <if test="storeId != null  and storeId != ''">#{storeId},</if>
            <if test="cash != null ">#{cash},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStorePaymentAccount" parameterType="StorePaymentAccount">
        update store_payment_account
        <trim prefix="SET" suffixOverrides=",">
            <if test="memberId != null  and memberId != ''">member_id = #{memberId},</if>
            <if test="accountNumber != null  and accountNumber != ''">account_number = #{accountNumber},</if>
            <if test="billDays != null  and billDays != ''">bill_days = #{billDays},</if>
            <if test="deptId != null  and deptId != ''">dept_id=#{deptId},</if>
            <if test="storeId != null  and storeId != ''">store_id = #{storeId},</if>
            <if test="cash != null ">cash = #{cash},</if>
            <if test="bondAccount != null ">bond_account = #{bondAccount},</if>
            <if test="rebateAccount != null ">rebate_account = #{rebateAccount},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where account_id = #{accountId}
    </update>

    <delete id="deleteStorePaymentAccountById" parameterType="String">
       update  store_payment_account set status=0,last_modify_time = now()  where account_id = #{accountId}
    </delete>

    <update id="deleteStorePaymentAccountByIds" parameterType="String">
        update  store_payment_account set status=0,last_modify_time = now() where account_id in
        <foreach item="accountId" collection="array" open="(" separator="," close=")">
            #{accountId}
        </foreach>
    </update>
    <update id="updateStorePaymentAccountCash" >
        update store_payment_account set  cash=#{cash},last_modify_time = now()  where account_id = #{accountId} and cash=#{oldCash}
    </update>
</mapper>