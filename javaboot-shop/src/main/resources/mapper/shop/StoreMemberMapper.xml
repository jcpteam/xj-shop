    <delete id="deleteStoreMemberById" parameterType="Long">
        update store_member set del_flag = '2' where id = #{id}
    </delete>

    <delete id="deleteStoreMemberByIds" parameterType="String">
        update store_member set del_flag = '2' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="updateStoreMemberQuotationId" parameterType="StoreMember">
        update store_member set quotation_id = #{quotationId} where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectSettlementList" parameterType="StoreMember" resultMap="StoreMemberResult">
        SELECT
            tb1.id, tb1.nickname,
            ( CASE WHEN tb1.settlement_type = '1' THEN tb1.id ELSE tb2.id END ) settlementId,
            ( CASE WHEN tb1.settlement_type = '1' THEN tb1.nickname ELSE tb2.nickname END ) settlementName
        FROM
            store_member tb1
            LEFT JOIN store_member tb2 ON tb1.super_customer = tb2.customer_no
        <where>
            <if test="ids != null  and ids.size()>0">
                AND tb1.id in
                <foreach collection="ids" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>

    </select>

    <select id="queryOpmanagerList" resultMap="StoreMemberResult">
        SELECT t1.opmanager_id,t1.id,t2.user_name as opmanagerName
        FROM
            store_member t1
            LEFT JOIN sys_user t2 ON t1.opmanager_id = t2.user_id
        where t1.del_flag = '0' and t1.opmanager_id is not null
    </select>

