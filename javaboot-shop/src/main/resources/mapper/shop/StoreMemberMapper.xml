    <sql id="selectStoreMemberVo">
        select tb1.id, tb1.customer_no, tb1.openid_qq, tb1.openid_wx, tb1.phone, tb1.password, tb1.nickname, tb1.headimg, tb1.sex, tb1.level,
        tb1.email, tb1.address, tb1.signature, tb1.total_amount, tb1.user_money, tb1.distribut_money, tb1.frozen_money, tb1.underling_number,
        tb1.pay_points, tb1.address_id, tb1.status, tb1.remark, tb1.create_time, tb1.create_at, tb1.status_time, tb1.customer_area, tb1.creditcode,
        tb1.customer_class, tb1.customer_type, tb1.super_customer, tb1.billing_cusotmer, tb1.card_number, tb1.receive_address, tb1.customer_kinds, tb1.quotation_id,
        tb1.contact_name,tb1.telephone,tb1.position,tb1.house_id,tb1.opmanager_id,tb1.settlement_type,tb1.delivery_type,tb1.print_type,
        ( CASE WHEN tb1.settlement_type = '1' THEN tb1.id ELSE tb2.id END ) settlementId,
        ( CASE WHEN tb1.settlement_type = '1' THEN tb1.nickname ELSE tb2.nickname END ) settlementName
        from store_member tb1
        LEFT JOIN store_member tb2 ON tb1.super_customer = tb2.customer_no
    </sql>

    <select id="selectStoreMemberList" parameterType="StoreMember" resultMap="StoreMemberResult">
        <include refid="selectStoreMemberVo"/>
        <where>
            tb1.del_flag = '0'
            <if test="id != null "> and tb1.id = #{id}</if>
            <if test="customerNo != null  and customerNo != ''"> and tb1.customer_no = #{customerNo}</if>
            <if test="openidQq != null  and openidQq != ''"> and tb1.openid_qq = #{openidQq}</if>
            <if test="openidWx != null  and openidWx != ''"> and tb1.openid_wx = #{openidWx}</if>
            <if test="phone != null  and phone != ''"> and tb1.phone = #{phone}</if>
            <if test="password != null  and password != ''"> and tb1.password = #{password}</if>
            <if test="nickname != null  and nickname != ''"> and tb1.nickname like concat('%', #{nickname}, '%')</if>
            <if test="headimg != null  and headimg != ''"> and tb1.headimg = #{headimg}</if>
            <if test="sex != null  and sex != ''"> and tb1.sex = #{sex}</if>
            <if test="level != null  and level != ''"> and tb1.level = #{level}</if>
            <if test="email != null  and email != ''"> and tb1.email = #{email}</if>
            <if test="address != null  and address != ''"> and tb1.address = #{address}</if>
            <if test="signature != null  and signature != ''"> and tb1.signature = #{signature}</if>
            <if test="totalAmount != null "> and tb1.total_amount = #{totalAmount}</if>
            <if test="userMoney != null "> and tb1.user_money = #{userMoney}</if>
            <if test="distributMoney != null "> and tb1.distribut_money = #{distributMoney}</if>
            <if test="frozenMoney != null "> and tb1.frozen_money = #{frozenMoney}</if>
            <if test="underlingNumber != null "> and tb1.underling_number = #{underlingNumber}</if>
            <if test="payPoints != null "> and tb1.pay_points = #{payPoints}</if>
            <if test="addressId != null "> and tb1.address_id = #{addressId}</if>
            <if test="status != null "> and tb1.status = #{status}</if>
            <if test="createAt != null "> and tb1.create_at = #{createAt}</if>
            <if test="statusTime != null "> and tb1.status_time = #{statusTime}</if>
            <if test="customerArea != null  and customerArea != ''  and customerArea != '-99'"> and tb1.customer_area = #{customerArea}</if>
            <if test="customerArea == '-99'"> and tb1.customer_area IS NULL</if>
            <if test="creditcode != null  and creditcode != ''"> and tb1.creditcode = #{creditcode}</if>
            <if test="customerClass != null  and customerClass != ''"> and tb1.customer_class = #{customerClass}</if>
            <if test="customerType != null  and customerType != ''"> and tb1.customer_type = #{customerType}</if>
            <if test="superCustomer != null  and superCustomer != ''"> and tb1.super_customer = #{superCustomer}</if>
            <if test="billingCusotmer != null  and billingCusotmer != ''"> and tb1.billing_cusotmer = #{billingCusotmer}</if>
            <if test="cardNumber != null  and cardNumber != ''"> and tb1.card_number = #{cardNumber}</if>
            <if test="receiveAddress != null  and receiveAddress != ''"> and tb1.receive_address = #{receiveAddress}</if>
            <if test="customerKinds != null  and customerKinds != ''"> and tb1.customer_kinds = #{customerKinds}</if>
            <if test="quotationId != null  and quotationId != '' and quotationId != '-99'">and tb1.quotation_id = #{quotationId}</if>
            <if test="quotationId == '-99'">and tb1.quotation_id IS NULL</if>
            <if test="opmanagerId != null  and opmanagerId != ''">and tb1.opmanager_id = #{opmanagerId}</if>
            <if test="deliveryType != null  and deliveryType != ''">and tb1.delivery_type = #{deliveryType}</if>
            <if test="printType != null  and printType != ''">and tb1.print_type = #{printType}</if>
            <if test="ids != null  and ids.size()>0">
                AND tb1.id in
                <foreach collection="ids" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
             </if>
            <if test="customerNOs != null  and customerNOs.size()>0">
                AND tb1.customer_no in
                <foreach collection="customerNOs" item="customerNo" open="(" separator="," close=")">
                    #{customerNo}
                </foreach>
            </if>
            <if test="quotationIds != null  and quotationIds.size()>0">
                AND tb1.quotation_id in
                <foreach collection="quotationIds" item="quotationId" open="(" separator="," close=")">
                    #{quotationId}
                </foreach>
            </if>
            <if test="settlementName != null  and settlementName != ''">
              AND  (CASE WHEN tb1.settlement_type = '1' THEN tb1.nickname like concat('%', #{settlementName}, '%') ELSE tb2.nickname like concat('%', #{settlementName}, '%') END )
            </if>
        </where>
    </select>

    <select id="selectStoreMemberById" parameterType="Long" resultMap="StoreMemberResult">
        <include refid="selectStoreMemberVo"/>
        where tb1.id = #{id}
    </select>

