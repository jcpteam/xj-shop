<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreWarehouseStockMapper">
    
    <resultMap type="com.javaboot.shop.vo.StoreWarehouseStockVO" id="StoreWarehouseStockResult">
        <result property="stockId"    column="stock_id"    />
        <result property="stockNo"    column="stock_no"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="stockType"    column="stock_type"    />
        <result property="status"    column="status"    />
        <result property="comment"    column="comment"    />
        <result property="synStatus"    column="syn_status"    />
        <result property="auditStatus"    column="audit_status"    />
        <result property="category"    column="category"    />
        <result property="objectId"    column="object_id"    />
        <result property="insertTime"    column="insert_time"    />
        <result property="adjustAmount"    column="adjust_amount"    />
        <result property="purchaseDate"    column="purchase_date"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreWarehouseStockVo">
        select * from store_warehouse_stock
    </sql>

    <select id="selectStoreWarehouseStockList" parameterType="StoreWarehouseStock" resultMap="StoreWarehouseStockResult">
        <include refid="selectStoreWarehouseStockVo"/>
        <where>
            AND status=1
            <if test="stockNo != null  and stockNo != ''"> and stock_no = #{stockNo}</if>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="deptId != null and deptId != '' "> and dept_id = #{deptId}</if>
            <if test="category != null and category != '' "> and category = #{category}</if>
            <if test="objectId != null and objectId != '' "> and object_id = #{objectId}</if>
            <if test="stockType != null  and stockType != ''"> and stock_type = #{stockType}</if>
            <if test="synStatus != null  and synStatus != ''"> and syn_status = #{synStatus}</if>
            <if test="supplierId != null and supplierId != ''">and supplier_id = #{supplierId}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
            <if test="purchaseDate != null "> and purchase_date = #{purchaseDate}</if>
            <if test="createTime != null "> and create_time = #{createTime}</if>
            <if test="loginUserDeptId != null  and loginUserDeptId !='' and (deptId==null or deptId=='')">
                AND  dept_id IN (
                SELECT
                dept_id
                FROM
                sys_dept
                WHERE
                find_in_set( #{loginUserDeptId}, ancestors )  or dept_id=#{loginUserDeptId}
                )
            </if>
            <if test="beginDate != null and beginDate!='' and endDate != null and endDate!='' ">
                and insert_time  BETWEEN
                DATE_FORMAT(#{beginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{endDate},'%Y-%m-%d %H:%i:%s')
            </if>
            <if test="stockBeginDate != null and stockBeginDate!='' and stockEndDate != null and stockEndDate!='' ">
                and create_time  BETWEEN
                DATE_FORMAT(#{stockBeginDate},'%Y-%m-%d')
                AND DATE_FORMAT(#{stockEndDate},'%Y-%m-%d')
            </if>
            <if test="purchaseBeginDate != null and purchaseBeginDate!='' and purchaseEndDate != null and purchaseEndDate!='' ">
                and purchase_date  BETWEEN
                DATE_FORMAT(#{purchaseBeginDate},'%Y-%m-%d')
                AND DATE_FORMAT(#{purchaseEndDate},'%Y-%m-%d')
            </if>
        </where>
        <if test="reqPage != null">
            LIMIT #{reqPage.pagePreNum} OFFSET #{reqPage.pageNo}
        </if>
    </select>
    
    <select id="selectStoreWarehouseStockById" parameterType="Long" resultMap="StoreWarehouseStockResult">
        <include refid="selectStoreWarehouseStockVo"/>
        where stock_id = #{stockId}
    </select>
        
    <insert id="insertStoreWarehouseStock" parameterType="StoreWarehouseStock" useGeneratedKeys="true" keyProperty="stockId">
        insert into store_warehouse_stock
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="stockNo != null  and stockNo != ''">stock_no,</if>
            <if test="warehouseId != null ">warehouse_id,</if>
            <if test="supplierId != null and supplierId != ''">supplier_id,</if>
            <if test="deptId != null ">dept_id,</if>
            <if test="stockType != null  and stockType != ''">stock_type,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="comment != null  and comment != ''">comment,</if>
            <if test="category != null  and category != ''">category,</if>
            <if test="objectId != null  and objectId != ''">object_id,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="purchaseDate != null ">purchase_date,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
            <if test="adjustAmount != null  and adjustAmount!=''">adjust_amount,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="stockNo != null  and stockNo != ''">#{stockNo},</if>
            <if test="warehouseId != null ">#{warehouseId},</if>
            <if test="supplierId != null and supplierId != ''">#{supplierId},</if>
            <if test="deptId != null ">#{deptId},</if>
            <if test="stockType != null  and stockType != ''">#{stockType},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="comment != null  and comment != ''">#{comment},</if>
            <if test="category != null  and category != ''">#{category},</if>
            <if test="objectId != null  and objectId != ''">#{objectId},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="purchaseDate != null ">#{purchaseDate},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
            <if test="adjustAmount != null  and adjustAmount!=''">#{adjustAmount},</if>
         </trim>
    </insert>

    <update id="updateStoreWarehouseStock" parameterType="StoreWarehouseStock">
        update store_warehouse_stock
        <trim prefix="SET" suffixOverrides=",">
            <if test="stockNo != null  and stockNo != ''">stock_no = #{stockNo},</if>
            <if test="warehouseId != null ">warehouse_id = #{warehouseId},</if>
            <if test="supplierId != null and supplierId != ''">supplier_id = #{supplierId},</if>
            <if test="deptId != null ">dept_id = #{deptId},</if>
            <if test="stockType != null  and stockType != ''">stock_type = #{stockType},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="purchaseDate != null ">purchase_date = #{purchaseDate},</if>
            <if test="status != null and status!='' ">status = #{status},</if>
            <if test="comment != null  and comment != ''">comment = #{comment},</if>
            <if test="synStatus != null  and synStatus != ''"> syn_status = #{synStatus},</if>
            <if test="category != null and category!='' ">category = #{category},</if>
            <if test="objectId != null and objectId!='' ">object_id = #{objectId},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
            <if test="auditStatus != null ">audit_status = #{auditStatus},</if>
            <if test="adjustAmount != null  and adjustAmount!=''">adjust_amount = #{adjustAmount},</if>
        </trim>
        where stock_id = #{stockId}
    </update>

    <update id="deleteStoreWarehouseStockById" parameterType="Long">
        update store_warehouse_stock set status=0,last_modify_time = now() where stock_id = #{stockId}
    </update>

    <update id="deleteStoreWarehouseStockByIds" parameterType="String">
        update store_warehouse_stock set status=0,last_modify_time = now() where stock_id in
        <foreach item="stockId" collection="array" open="(" separator="," close=")">
            #{stockId}
        </foreach>
    </update>

    <update id="updateStockAuditStatusByIds" parameterType="map">
        update store_warehouse_stock set audit_status=#{auditStatus},syn_status='0',last_modify_time = now() where stock_id in
        <foreach item="stockId" collection="stockIdList" open="(" separator="," close=")">
            #{stockId}
        </foreach>
    </update>
</mapper>