<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreMessageMapper">

    <resultMap type="StoreMessage" id="StoreMessageResult">
        <result property="id"    column="id"    />
        <result property="messageKey"    column="message_key"    />
        <result property="status"    column="status"    />
        <result property="readStatus"    column="read_status"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="merchantId"    column="merchant_id"    />
        <result property="receiveId"    column="receive_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreMessageVo">
        select id, message_key, status, read_status, title, content, merchant_id, receive_id, create_time, last_modify_time from store_message
    </sql>

    <select id="selectStoreMessageList" parameterType="StoreMessage" resultMap="StoreMessageResult">
        <!--<include refid="selectStoreMessageVo"/>-->
        select id, message_key, status, read_status, title, content, merchant_id, receive_id, create_time, last_modify_time from store_message
        <where>
            status = '1'
            <if test="messageKey != null  and messageKey != ''"> and message_key = #{messageKey}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="readStatus != null  and readStatus != ''"> and read_status = #{readStatus}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="merchantId != null  and merchantId != ''"> and merchant_id = #{merchantId}</if>
            <if test="receiveId != null  and receiveId != ''"> and receive_id = #{receiveId}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectStoreMessageById" parameterType="Long" resultMap="StoreMessageResult">
        <include refid="selectStoreMessageVo"/>
        where id = #{id}
    </select>

    <insert id="insertStoreMessage" parameterType="StoreMessage" useGeneratedKeys="true" keyProperty="id">
        insert into store_message
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="messageKey != null  and messageKey != ''">message_key,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="readStatus != null  and readStatus != ''">read_status,</if>
            <if test="title != null  and title != ''">title,</if>
            <if test="content != null  and content != ''">content,</if>
            <if test="merchantId != null  and merchantId != ''">merchant_id,</if>
            <if test="receiveId != null  and receiveId != ''">receive_id,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="messageKey != null  and messageKey != ''">#{messageKey},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="readStatus != null  and readStatus != ''">#{readStatus},</if>
            <if test="title != null  and title != ''">#{title},</if>
            <if test="content != null  and content != ''">#{content},</if>
            <if test="merchantId != null  and merchantId != ''">#{merchantId},</if>
            <if test="receiveId != null  and receiveId != ''">#{receiveId},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
        </trim>
    </insert>

    <update id="updateStoreMessage" parameterType="StoreMessage">
        update store_message
        <trim prefix="SET" suffixOverrides=",">
            <if test="messageKey != null  and messageKey != ''">message_key = #{messageKey},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="readStatus != null  and readStatus != ''">read_status = #{readStatus},</if>
            <if test="title != null  and title != ''">title = #{title},</if>
            <if test="content != null  and content != ''">content = #{content},</if>
            <if test="merchantId != null  and merchantId != ''">merchant_id = #{merchantId},</if>
            <if test="receiveId != null  and receiveId != ''">receive_id = #{receiveId},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStoreMessageById" parameterType="Long">
        delete from store_message where id = #{id}
    </delete>

    <delete id="deleteStoreMessageByIds" parameterType="String">
        delete from store_message where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>