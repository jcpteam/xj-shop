<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreDriverInfoMapper">
    
    <resultMap type="StoreDriverInfo" id="StoreDriverInfoResult">
        <result property="driverId"    column="driver_id"    />
        <result property="driverName"    column="driver_name"    />
        <result property="driverLicense"    column="driver_license"    />
        <result property="driverPhone"    column="driver_phone"    />
        <result property="deptId"    column="dept_id"    />
        <result property="routeId"    column="route_id"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreDriverInfoVo">
--         select driver_id, driver_name, driver_license, driver_phone, dept_id, route_id, status, create_time, last_modify_time from store_driver_info
        select t1.driver_id, t1.driver_name, t1.driver_license, t1.driver_phone, t1.dept_id, t1.route_id, t1.status, t1.create_time, t1.last_modify_time,
               d.dept_name,r.route_name
        from store_driver_info t1
        left join sys_dept d on t1.dept_id = d.dept_id
        left join store_deliver_route r on t1.route_id = r.route_id
    </sql>

    <select id="selectStoreDriverInfoList" parameterType="StoreDriverInfo" resultMap="StoreDriverInfoResult">
        <include refid="selectStoreDriverInfoVo"/>
        <where>  
            <if test="driverName != null  and driverName != ''"> and driver_name like concat('%', #{driverName}, '%')</if>
            <if test="deptId != null and deptId != ''"> and d.dept_id = #{deptId}</if>
        </where>
    </select>
    
    <select id="selectStoreDriverInfoById" parameterType="Long" resultMap="StoreDriverInfoResult">
        <include refid="selectStoreDriverInfoVo"/>
        where driver_id = #{driverId}
    </select>
        
    <insert id="insertStoreDriverInfo" parameterType="StoreDriverInfo" useGeneratedKeys="true" keyProperty="driverId">
        insert into store_driver_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="driverName != null  and driverName != ''">driver_name,</if>
            <if test="driverLicense != null  and driverLicense != ''">driver_license,</if>
            <if test="driverPhone != null  and driverPhone != ''">driver_phone,</if>
            <if test="deptId != null ">dept_id,</if>
            <if test="routeId != null ">route_id,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="driverName != null  and driverName != ''">#{driverName},</if>
            <if test="driverLicense != null  and driverLicense != ''">#{driverLicense},</if>
            <if test="driverPhone != null  and driverPhone != ''">#{driverPhone},</if>
            <if test="deptId != null ">#{deptId},</if>
            <if test="routeId != null ">#{routeId},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreDriverInfo" parameterType="StoreDriverInfo">
        update store_driver_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="driverName != null  and driverName != ''">driver_name = #{driverName},</if>
            <if test="driverLicense != null  and driverLicense != ''">driver_license = #{driverLicense},</if>
            <if test="driverPhone != null  and driverPhone != ''">driver_phone = #{driverPhone},</if>
            <if test="deptId != null ">dept_id = #{deptId},</if>
            <if test="routeId != null ">route_id = #{routeId},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where driver_id = #{driverId}
    </update>

    <delete id="deleteStoreDriverInfoById" parameterType="Long">
        delete from store_driver_info where driver_id = #{driverId}
    </delete>

    <delete id="deleteStoreDriverInfoByIds" parameterType="String">
        delete from store_driver_info where driver_id in 
        <foreach item="driverId" collection="array" open="(" separator="," close=")">
            #{driverId}
        </foreach>
    </delete>
    
</mapper>