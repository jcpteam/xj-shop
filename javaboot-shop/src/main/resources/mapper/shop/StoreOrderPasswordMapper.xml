<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreOrderPasswordMapper">
    
    <resultMap type="StoreOrderPassword" id="StoreOrderPasswordResult">
        <result property="id"    column="id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="deptName"    column="dept_name"    />
        <result property="password"    column="password"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreOrderPasswordVo">
        select id, dept_id, password, status, create_time, last_modify_time from store_order_password
    </sql>

    <select id="selectStoreOrderPasswordList" parameterType="StoreOrderPassword" resultMap="StoreOrderPasswordResult">
        SELECT
            t1.id,
            t1.dept_id,
            t2.dept_name,
            t1.PASSWORD,
            t1.STATUS,
            t1.create_time,
            t1.last_modify_time
        FROM
            store_order_password t1,
            sys_dept t2
        <where>
            t1.dept_id = t2.dept_id
            <if test="deptId != null  and deptId != ''"> and t1.dept_id = #{deptId}</if>
            <if test="password != null  and password != ''"> and t1.password = #{password}</if>
            <if test="status != null  and status != ''"> and t1.status = #{status}</if>
            <if test="lastModifyTime != null "> and t1.last_modify_time = #{lastModifyTime}</if>
        </where>
    </select>
    
    <select id="selectStoreOrderPasswordById" parameterType="Long" resultMap="StoreOrderPasswordResult">
        <include refid="selectStoreOrderPasswordVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertStoreOrderPassword" parameterType="StoreOrderPassword" useGeneratedKeys="true" keyProperty="id">
        insert into store_order_password
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="password != null  and password != ''">password,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="password != null  and password != ''">#{password},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreOrderPassword" parameterType="StoreOrderPassword">
        update store_order_password
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="password != null  and password != ''">password = #{password},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStoreOrderPasswordById" parameterType="Long">
        delete from store_order_password
    </delete>

    <delete id="deleteStoreOrderPasswordByIds" parameterType="String">
        delete from store_order_password where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>