<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreGoodsSpuMapper">

    <resultMap type="com.javaboot.shop.vo.StoreGoodsSpuVO" id="StoreGoodsSpuResult">
        <result property="spuNo" column="spu_no"/>
        <result property="code" column="code"/>
        <result property="image" column="image"/>
        <result property="name" column="name"/>
        <result property="unit" column="unit"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="classifyId" column="classify_id"/>
        <result property="createTime" column="create_time"/>
        <result property="lastModifyTime" column="last_modify_time"/>
    </resultMap>

    <sql id="selectStoreGoodsSpuVo">
        select spu_no, code,classify_id, image, name,  unit, description, status, create_time, last_modify_time from store_goods_spu
    </sql>

    <select id="selectStoreGoodsSpuList" parameterType="com.javaboot.shop.domain.StoreGoodsSpu"
            resultMap="StoreGoodsSpuResult">
        <include refid="selectStoreGoodsSpuVo"/>
        <where>
            AND status !=0
            <if test="searchKey != null and searchKey!=''"> and (name like concat('%', #{searchKey}, '%') or code like concat('%', #{searchKey}, '%') )</if>
            <if test="code != null  and code != ''">and code = #{code}</if>
            <if test="image != null  and image != ''">and image = #{image}</if>
            <if test="classifyId != null  and classifyId != ''">and classify_id = #{classifyId}</if>
            <if test="name != null  and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="unit != null  and unit != ''">and unit = #{unit}</if>
            <if test="description != null  and description != ''">and description = #{description}</if>
            <if test="status != null  and status != ''">and status = #{status}</if>
            <if test="lastModifyTime != null ">and last_modify_time = #{lastModifyTime}</if>
        </where>
    </select>

    <select id="selectStoreGoodsSpuById" parameterType="String" resultMap="StoreGoodsSpuResult">
        <include refid="selectStoreGoodsSpuVo"/>
        where spu_no = #{spuNo}
    </select>

    <insert id="insertStoreGoodsSpu" parameterType="com.javaboot.shop.domain.StoreGoodsSpu">
        insert into store_goods_spu
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="spuNo != null ">spu_no,</if>
            <if test="code != null  and code != ''">code,</if>
            <if test="image != null  and image != ''">image,</if>
            <if test="name != null  and name != ''">name,</if>
            <if test="unit != null  and unit != ''">unit,</if>
            <if test="description != null  and description != ''">description,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="classifyId != null  and classifyId != ''">classify_id,</if>
            create_time, last_modify_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="spuNo != null ">#{spuNo},</if>
            <if test="code != null  and code != ''">#{code},</if>
            <if test="image != null  and image != ''">#{image},</if>
            <if test="name != null  and name != ''">#{name},</if>
            <if test="unit != null  and unit != ''">#{unit},</if>
            <if test="description != null  and description != ''">#{description},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="classifyId != null  and classifyId != ''">#{classifyId},</if>
            now(),now()
        </trim>
    </insert>

    <update id="updateStoreGoodsSpu" parameterType="com.javaboot.shop.domain.StoreGoodsSpu">
        update store_goods_spu
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null  and code != ''">code = #{code},</if>
            <if test="image != null  and image != ''">image = #{image},</if>
            <if test="classifyId != null  and classifyId != ''">classify_id = #{classifyId},</if>
            <if test="name != null  and name != ''">name = #{name},</if>
            <if test="unit != null  and unit != ''">unit = #{unit},</if>
            <if test="description != null  and description != ''">description = #{description},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            last_modify_time = now()
        </trim>
        where spu_no = #{spuNo}
    </update>

    <delete id="deleteStoreGoodsSpuById" parameterType="Long">
        delete from store_goods_spu where spu_no = #{spuNo}
    </delete>

    <delete id="deleteStoreGoodsSpuByIds" parameterType="String">
        delete from store_goods_spu where spu_no in
        <foreach item="spuNo" collection="array" open="(" separator="," close=")">
            #{spuNo}
        </foreach>
    </delete>

</mapper>