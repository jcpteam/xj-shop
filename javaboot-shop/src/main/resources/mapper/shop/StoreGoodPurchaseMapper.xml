<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreGoodPurchaseMapper">
    
    <resultMap type="com.javaboot.shop.vo.StoreGoodPurchaseVO" id="StoreGoodPurchaseResult">
        <result property="purchaseId"    column="purchase_id"    />
        <result property="purchaseNo"    column="purchase_no"    />
        <result property="deptId"    column="dept_id"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="purchaseDate"    column="purchase_date"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="status"    column="status"    />
        <result property="comment"    column="comment"    />
        <result property="adjustAmount"    column="adjust_amount"    />
        <result property="stockStatus"    column="stock_status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
        <result property="stockTime"    column="stock_time"    />
    </resultMap>

    <sql id="selectStoreGoodPurchaseVo">
        select * from store_good_purchase
    </sql>

    <select id="selectStoreGoodPurchaseList" parameterType="StoreGoodPurchase" resultMap="StoreGoodPurchaseResult">
        SELECT t1.*, t2.create_time as stock_time FROM store_good_purchase t1
        LEFT JOIN store_warehouse_stock  t2 ON t1.purchase_id = t2.object_id AND t2.category = '4' AND t2.status='1'
        <where>
            AND t1.status=1
            <if test="purchaseNo != null  and purchaseNo != ''"> and t1.purchase_no = #{purchaseNo}</if>
            <if test="stockStatus != null  and stockStatus != ''"> and t1.stock_status = #{stockStatus}</if>
            <if test="deptId != null and deptId != ''"> and t1.dept_id = #{deptId}</if>
            <if test="warehouseId != null ">and t1.warehouse_id = #{warehouseId}</if>
            <if test="purchaseDate != null ">and t1.purchase_date = #{purchaseDate}</if>
            <if test="supplierId != null and supplierId != '' ">and t1.supplier_id = #{supplierId}</if>
            <if test="lastModifyTime != null "> and t1.last_modify_time = #{lastModifyTime}</if>
            <if test="loginUserDeptId != null  and loginUserDeptId !=''and (deptId==null or deptId=='')">
                AND  t1.dept_id IN (
                SELECT
                dept_id
                FROM
                sys_dept
                WHERE
                find_in_set( #{loginUserDeptId}, ancestors ) OR dept_id=#{loginUserDeptId}
                )
            </if>
            <if test="purchaseBeginDate != null and purchaseBeginDate!='' and purchaseEndDate != null and purchaseEndDate!='' ">
                and t1.purchase_date  BETWEEN
                DATE_FORMAT(#{purchaseBeginDate},'%Y-%m-%d')
                AND DATE_FORMAT(#{purchaseEndDate},'%Y-%m-%d')
            </if>
            <if test="beginDate != null and beginDate!='' and endDate != null and endDate!='' ">
                and t1.create_time  BETWEEN
                DATE_FORMAT(#{beginDate},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{endDate},'%Y-%m-%d %H:%i:%s')
            </if>
        </where>
    </select>
    
    <select id="selectStoreGoodPurchaseById" parameterType="Long" resultMap="StoreGoodPurchaseResult">
        <include refid="selectStoreGoodPurchaseVo"/>
        where purchase_id = #{purchaseId}
    </select>
        
    <insert id="insertStoreGoodPurchase" parameterType="StoreGoodPurchase" useGeneratedKeys="true" keyProperty="purchaseId">
        insert into store_good_purchase
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="purchaseNo != null  and purchaseNo != ''">purchase_no,</if>
            <if test="deptId != null ">dept_id,</if>
            <if test="warehouseId != null ">warehouse_id,</if>
            <if test="purchaseDate != null ">purchase_date,</if>
            <if test="supplierId != null and supplierId != '' ">supplier_id,</if>
            <if test="status != null  and status!=''">status,</if>
            <if test="comment != null  and comment!=''">comment,</if>
            <if test="adjustAmount != null  and adjustAmount!=''">adjust_amount,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="purchaseNo != null  and purchaseNo != ''">#{purchaseNo},</if>
            <if test="deptId != null ">#{deptId},</if>
            <if test="warehouseId != null ">#{warehouseId},</if>
            <if test="purchaseDate != null ">#{purchaseDate},</if>
            <if test="supplierId != null and supplierId != '' ">#{supplierId},</if>
            <if test="status != null  and status!=''">#{status},</if>
            <if test="comment != null  and comment!=''">#{comment},</if>
            <if test="adjustAmount != null  and adjustAmount!=''">#{adjustAmount},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreGoodPurchase" parameterType="StoreGoodPurchase">
        update store_good_purchase
        <trim prefix="SET" suffixOverrides=",">
            <if test="purchaseNo != null  and purchaseNo != ''">purchase_no = #{purchaseNo},</if>
            <if test="deptId != null ">dept_id = #{deptId},</if>
            <if test="warehouseId != null ">warehouse_id = #{warehouseId},</if>
            <if test="purchaseDate != null ">purchase_date = #{purchaseDate},</if>
            <if test="supplierId != null and supplierId != '' ">supplier_id = #{supplierId},</if>
            <if test="status != null  and status!=''">status = #{status},</if>
            <if test="comment != null  and comment!=''">comment = #{comment},</if>
            <if test="adjustAmount != null  and adjustAmount!=''">adjust_amount = #{adjustAmount},</if>
            <if test="stockStatus != null  and stockStatus!=''">stock_status = #{stockStatus},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where purchase_id = #{purchaseId}
    </update>

    <update id="deleteStoreGoodPurchaseById" parameterType="Long">
         update   store_good_purchase set status=0,last_modify_time = now()  where purchase_id = #{purchaseId}
    </update>

    <update id="deleteStoreGoodPurchaseByIds" parameterType="String">
        update   store_good_purchase set status=0,last_modify_time = now()   where purchase_id in
        <foreach item="purchaseId" collection="array" open="(" separator="," close=")">
            #{purchaseId}
        </foreach>
    </update>
    
</mapper>