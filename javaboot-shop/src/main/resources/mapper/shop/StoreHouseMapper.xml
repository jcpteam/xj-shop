<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreHouseMapper">
    
    <resultMap type="StoreHouse" id="StoreHouseResult">
        <result property="storeId"    column="store_id"    />
        <result property="storeNo"    column="store_no"    />
        <result property="storeName"    column="store_name"    />
        <result property="deptId"    column="dept_id"    />
        <result property="storeType"    column="store_type"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreHouseVo">
        select h.store_id, h.store_no, h.store_name, h.dept_id, h.store_type, h.status, h.create_time, h.last_modify_time,d.dept_name
        from store_house h
        left join sys_dept d on h.dept_id = d.dept_id
    </sql>

    <select id="selectStoreHouseList" parameterType="StoreHouse" resultMap="StoreHouseResult">
        <include refid="selectStoreHouseVo"/>
        <where>
            <if test="storeNo != null  and storeNo != ''"> and h.store_no = #{storeNo}</if>
            <if test="storeName != null  and storeName != ''"> and h.store_name like concat('%', #{storeName}, '%')</if>
            <if test="deptId != null "> and h.dept_id = #{deptId}</if>
        </where>
    </select>
    <select id="selectStoreHouseListByIds" parameterType="StoreHouse" resultMap="StoreHouseResult">
        <include refid="selectStoreHouseVo"/>
        <where>
            AND store_id in
            <foreach item="id" collection="idList" open="(" separator="," close=")">
                #{id}
            </foreach>
        </where>
    </select>
    <select id="selectStoreHouseById" parameterType="Long" resultMap="StoreHouseResult">
        <include refid="selectStoreHouseVo"/>
        where store_id = #{storeId}
    </select>
        
    <insert id="insertStoreHouse" parameterType="StoreHouse" useGeneratedKeys="true" keyProperty="storeId">
        insert into store_house
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="storeNo != null  and storeNo != ''">store_no,</if>
            <if test="storeName != null  and storeName != ''">store_name,</if>
            <if test="deptId != null ">dept_id,</if>
            <if test="storeType != null  and storeType != ''">store_type,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="storeNo != null  and storeNo != ''">#{storeNo},</if>
            <if test="storeName != null  and storeName != ''">#{storeName},</if>
            <if test="deptId != null ">#{deptId},</if>
            <if test="storeType != null  and storeType != ''">#{storeType},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreHouse" parameterType="StoreHouse">
        update store_house
        <trim prefix="SET" suffixOverrides=",">
            <if test="storeNo != null  and storeNo != ''">store_no = #{storeNo},</if>
            <if test="storeName != null  and storeName != ''">store_name = #{storeName},</if>
            <if test="deptId != null ">dept_id = #{deptId},</if>
            <if test="storeType != null  and storeType != ''">store_type = #{storeType},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where store_id = #{storeId}
    </update>

    <delete id="deleteStoreHouseById" parameterType="Long">
        delete from store_house where store_id = #{storeId}
    </delete>

    <delete id="deleteStoreHouseByIds" parameterType="String">
        delete from store_house where store_id in 
        <foreach item="storeId" collection="array" open="(" separator="," close=")">
            #{storeId}
        </foreach>
    </delete>
    
</mapper>