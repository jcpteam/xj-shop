<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreOrderMapper">
    
    <resultMap type="StoreOrder" id="StoreOrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="orderSn"    column="order_sn"    />
        <result property="userId"    column="user_id"    />
        <result property="orderStatus"    column="order_status"    />
        <result property="payStatus"    column="pay_status"    />
        <result property="payMethod"    column="pay_method"    />
        <result property="payName"    column="pay_name"    />
        <result property="couponPrice"    column="coupon_price"    />
        <result property="orderAmount"    column="order_amount"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="addTime"    column="add_time"    />
        <result property="payTime"    column="pay_time"    />
        <result property="deleted"    column="deleted"    />
        <result property="goodsId"    column="goods_id"    />
        <result property="goodsName"    column="goods_name"    />
        <result property="specKey"    column="spec_key"    />
        <result property="specKeyName"    column="spec_key_name"    />
        <result property="specName"    column="spec_name"    />
        <result property="authName"    column="auth_name"    />
        <result property="expirationTime"    column="expiration_time"    />

        <association property="storeMember" column="user_id" select="com.javaboot.shop.mapper.StoreMemberMapper.selectStoreMemberById"/>

    </resultMap>

    <sql id="selectStoreOrderVo">
        select order_id,order_sn,user_id,order_status,pay_status,pay_method,pay_name,coupon_price,order_amount,total_amount,add_time,pay_time,deleted,goods_id,goods_name,spec_key,spec_key_name,spec_name,auth_name,expiration_time from store_order
    </sql>

    <select id="selectStoreOrderList" parameterType="StoreOrder" resultMap="StoreOrderResult">
        <include refid="selectStoreOrderVo"/>
        <where>
            <if test="userId != null  and userId != ''"> and user_id = #{userId}</if>
            <if test="orderSn != null  and orderSn != ''"> and order_sn = #{orderSn}</if>
            <if test="orderStatus != null "> and order_status = #{orderStatus}</if>
            <if test="payStatus != null "> and pay_status = #{payStatus}</if>
            <if test="deleted != null "> and deleted = #{deleted}</if>
            <if test="payMethod != null "> and pay_method = #{payMethod}</if>
            <if test="couponPrice != null "> and coupon_price = #{couponPrice}</if>
            <if test="orderAmount != null "> and order_amount = #{orderAmount}</if>
            <if test="totalAmount != null "> and total_amount = #{totalAmount}</if>
            <if test="goodsId != null "> and goods_id = #{goodsId}</if>
            <if test="goodsName != null "> and goods_name = #{goodsName}</if>
            <if test="specKey != null "> and spec_key = #{specKey}</if>
            <if test="specKeyName != null "> and spec_key_name = #{specKeyName}</if>
            <if test="specName != null  and specName != ''"> and spec_name = #{specName}</if>
            <if test="authName != null  and authName != ''"> and auth_name = #{authName}</if>
            <if test="expirationTime != null  and expirationTime != ''"> and expiration_time = #{expirationTime}</if>
        </where>
    </select>
    
    <select id="selectStoreOrderById" parameterType="Integer" resultMap="StoreOrderResult">
        <include refid="selectStoreOrderVo"/>
        where order_id = #{orderId}
    </select>
        
    <insert id="insertStoreOrder" parameterType="StoreOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into store_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderSn != null  and orderSn != ''">order_sn,</if>
            <if test="userId != null ">user_id,</if>
            <if test="orderStatus != null ">order_status,</if>
            <if test="payStatus != null ">pay_status,</if>
            <if test="payMethod != null ">pay_method,</if>
            <if test="payName != null and payName != ''">pay_name,</if>
            <if test="couponPrice != null ">coupon_price,</if>
            <if test="orderAmount != null ">order_amount,</if>
            <if test="totalAmount != null ">total_amount,</if>
            <if test="addTime != null ">add_time,</if>
            <if test="payTime != null ">pay_time,</if>
            <if test="deleted != null ">deleted,</if>
            <if test="goodsId != null ">goods_id,</if>
            <if test="goodsName != null and goodsName != ''">goods_name,</if>
            <if test="specKey != null and specKey != ''">spec_key,</if>
            <if test="specKeyName != null and specKeyName != ''">spec_key_name,</if>
            <if test="specName != null and specName != ''">spec_name,</if>
            <if test="authName != null and authName != ''">auth_name,</if>
            <if test="expirationTime != null">expiration_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderSn != null and orderSn != ''">#{orderSn},</if>
            <if test="userId != null">#{userId},</if>
            <if test="orderStatus != null">#{orderStatus},</if>
            <if test="payStatus != null">#{payStatus},</if>
            <if test="payMethod != null">#{payMethod},</if>
            <if test="payName != null and payName != ''">#{payName},</if>
            <if test="couponPrice != null">#{couponPrice},</if>
            <if test="orderAmount != null">#{orderAmount},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="addTime != null">#{addTime},</if>
            <if test="payTime != null ">#{payTime},</if>
            <if test="deleted != null ">#{deleted},</if>
            <if test="goodsId != null ">#{goodsId},</if>
            <if test="goodsName != null and goodsName != ''">#{goodsName},</if>
            <if test="specKey != null and specKey != ''">#{specKey},</if>
            <if test="specKeyName != null and specKeyName != ''">#{specKeyName},</if>
            <if test="specName != null and specName != ''">#{specName},</if>
            <if test="authName != null and authName != ''">#{authName},</if>
            <if test="expirationTime != null">#{expirationTime},</if>
         </trim>
    </insert>

    <update id="updateStoreOrder" parameterType="StoreOrder">
        update store_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderSn != null  and orderSn != ''">order_sn = #{orderSn},</if>
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="orderStatus != null ">order_status = #{orderStatus},</if>
            <if test="payStatus != null ">pay_status = #{payStatus},</if>
            <if test="payMethod != null ">pay_method = #{payMethod},</if>
            <if test="payName != null  and payName != ''">pay_name = #{payName},</if>
            <if test="couponPrice != null ">coupon_price = #{couponPrice},</if>
            <if test="orderAmount != null ">order_amount = #{orderAmount},</if>
            <if test="totalAmount != null ">total_amount = #{totalAmount},</if>
            <if test="addTime != null ">add_time = #{addTime},</if>
            <if test="payTime != null ">pay_time = #{payTime},</if>
            <if test="deleted != null ">deleted = #{deleted},</if>
            <if test="goodsId != null ">goods_id = #{goodsId},</if>
            <if test="goodsName != null and goodsName != ''">goods_name = #{goodsName},</if>
            <if test="specKey != null and specKey != ''">spec_key = #{specKey},</if>
            <if test="specKeyName != null and specKeyName != ''">spec_key_name = #{specKeyName},</if>
            <if test="specName != null and specName != ''">spec_name = #{specName},</if>
            <if test="authName != null and authName != ''">auth_name = #{authName},</if>
            <if test="expirationTime != null">expiration_time = #{expirationTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteStoreOrderById" parameterType="Integer">
        delete from store_order where order_id = #{orderId}
    </delete>

    <update id="deleteStoreOrderByIds" parameterType="String">
        update store_order set deleted = 1
         where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </update>
    
</mapper>