<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreGoodsSalesUnitMapper">

    <resultMap type="com.javaboot.shop.domain.StoreGoodsSalesUnit" id="StoreGoodsSalesUnitResult">
        <result property="unitId" column="unit_id"/>
        <result property="name" column="name"/>
        <result property="settlementUnit" column="settlement_unit"/>
        <result property="conversionRelationship" column="conversion_relationship"/>
        <result property="orderNum" column="order_num"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="lastModifyTime" column="last_modify_time"/>
    </resultMap>

    <sql id="selectStoreGoodsSalesUnitVo">
        select unit_id, name, settlement_unit, conversion_relationship, order_num, status, create_time, last_modify_time from store_goods_sales_unit
    </sql>

    <select id="selectStoreGoodsSalesUnitList" parameterType="com.javaboot.shop.domain.StoreGoodsSalesUnit"
            resultMap="StoreGoodsSalesUnitResult">
        <include refid="selectStoreGoodsSalesUnitVo"/>
        <where>
            AND status !=0
            <if test="name != null  and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="settlementUnit != null  and settlementUnit != ''">and settlement_unit = #{settlementUnit}</if>
            <if test="conversionRelationship != null ">and conversion_relationship = #{conversionRelationship}</if>
            <if test="orderNum != null ">and order_num = #{orderNum}</if>
            <if test="status != null  and status != ''">and status = #{status}</if>
            <if test="lastModifyTime != null ">and last_modify_time = #{lastModifyTime}</if>
            <if test="unitIds !=null and unitIds.size() > 0 ">and unit_id in
                <foreach item="id" collection="unitIds" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
    </select>

    <select id="selectStoreGoodsSalesUnitById" parameterType="Long" resultMap="StoreGoodsSalesUnitResult">
        <include refid="selectStoreGoodsSalesUnitVo"/>
        where unit_id = #{unitId}
    </select>

    <insert id="insertStoreGoodsSalesUnit" parameterType="com.javaboot.shop.domain.StoreGoodsSalesUnit"
            useGeneratedKeys="true" keyProperty="unitId">
        insert into store_goods_sales_unit
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null  and name != ''">name,</if>
            <if test="settlementUnit != null  and settlementUnit != ''">settlement_unit,</if>
            <if test="conversionRelationship != null ">conversion_relationship,</if>
            <if test="orderNum != null ">order_num,</if>
            <if test="status != null  and status != ''">status,</if>
            create_time,last_modify_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null  and name != ''">#{name},</if>
            <if test="settlementUnit != null  and settlementUnit != ''">#{settlementUnit},</if>
            <if test="conversionRelationship != null ">#{conversionRelationship},</if>
            <if test="orderNum != null ">#{orderNum},</if>
            <if test="status != null  and status != ''">#{status},</if>
            now(),now()
        </trim>
    </insert>

    <update id="updateStoreGoodsSalesUnit" parameterType="com.javaboot.shop.domain.StoreGoodsSalesUnit">
        update store_goods_sales_unit
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null  and name != ''">name = #{name},</if>
            <if test="settlementUnit != null  and settlementUnit != ''">settlement_unit = #{settlementUnit},</if>
            <if test="conversionRelationship != null ">conversion_relationship = #{conversionRelationship},</if>
            <if test="orderNum != null ">order_num = #{orderNum},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            last_modify_time =now()
        </trim>
        where unit_id = #{unitId}
    </update>

    <update id="deleteStoreGoodsSalesUnitById" parameterType="Long">
       update   store_goods_sales_unit set status=0,last_modify_time =now() where unit_id = #{unitId}
    </update>

    <update id="deleteStoreGoodsSalesUnitByIds" parameterType="String">
        update store_goods_sales_unit set status=0,last_modify_time =now() where unit_id in
        <foreach item="unitId" collection="array" open="(" separator="," close=")">
            #{unitId}
        </foreach>
    </update>

</mapper>