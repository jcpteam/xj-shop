<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreSortingPerformanceDayMapper">
    
    <resultMap type="StoreSortingPerformanceDay" id="StoreSortingPerformanceDayResult">
        <result property="id"    column="id"    />
        <result property="monthId"    column="month_id"    />
        <result property="userId"    column="user_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="sortingDay"    column="sorting_day"    />
        <result property="result"    column="result"    />
        <result property="stockResult"    column="stock_result"    />
        <result property="adjustResult"    column="adjust_result"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreSortingPerformanceDayVo">
        select sspd.id, sspd.month_id, sspd.user_id, sspd.dept_id, sspd.sorting_day, sspd.result,sspd.stock_result,sspd.adjust_result, sspd.operator_id, sspd.status, sspd.create_time, sspd.last_modify_time
             ,d.dept_name,su.user_name,su1.user_name as operatorName
        from store_sorting_performance_day sspd
        left join sys_dept d on sspd.dept_id = d.dept_id
        left join sys_user su on sspd.user_id = su.user_id
        left join sys_user su1 on sspd.operator_id = su1.user_id
    </sql>

    <select id="selectStoreSortingPerformanceDayList" parameterType="StoreSortingPerformanceDay" resultMap="StoreSortingPerformanceDayResult">
        <include refid="selectStoreSortingPerformanceDayVo"/>
        <where>
            sspd.status != '0'
            <if test="monthId != null "> and sspd.month_id = #{monthId}</if>
            <if test="userId != null "> and sspd.user_id = #{userId}</if>
            <if test="deptId != null  and deptId != ''"> and sspd.dept_id = #{deptId}</if>
            <if test="sortingDay != null  and sortingDay != ''"> and sspd.sorting_day = #{sortingDay}</if>
        </where>
    </select>
    
    <select id="selectStoreSortingPerformanceDayById" parameterType="Long" resultMap="StoreSortingPerformanceDayResult">
        <include refid="selectStoreSortingPerformanceDayVo"/>
        where sspd.id = #{id}
    </select>
        
    <insert id="insertStoreSortingPerformanceDay" parameterType="StoreSortingPerformanceDay" useGeneratedKeys="true" keyProperty="id">
        insert into store_sorting_performance_day
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="monthId != null ">month_id,</if>
            <if test="userId != null ">user_id,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="sortingDay != null  and sortingDay != ''">sorting_day,</if>
            <if test="result != null ">result,</if>
            <if test="stockResult != null ">stock_result,</if>
            <if test="adjustResult != null ">adjust_result,</if>
            <if test="operatorId != null ">operator_id,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="monthId != null ">#{monthId},</if>
            <if test="userId != null ">#{userId},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="sortingDay != null  and sortingDay != ''">#{sortingDay},</if>
            <if test="result != null ">#{result},</if>
            <if test="stockResult != null ">#{stockResult},</if>
            <if test="adjustResult != null ">#{adjustResult},</if>
            <if test="operatorId != null ">#{operatorId},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreSortingPerformanceDay" parameterType="StoreSortingPerformanceDay">
        update store_sorting_performance_day
        <trim prefix="SET" suffixOverrides=",">
            <if test="monthId != null ">month_id = #{monthId},</if>
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="sortingDay != null  and sortingDay != ''">sorting_day = #{sortingDay},</if>
            <if test="result != null ">result = #{result},</if>
            <if test="stockResult != null ">stock_result = #{stockResult},</if>
            <if test="adjustResult != null ">adjust_result = #{adjustResult},</if>
            <if test="operatorId != null ">operator_id = #{operatorId},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStoreSortingPerformanceDayById" parameterType="Long">
        delete from store_sorting_performance_day where id = #{id}
    </delete>

    <delete id="deleteStoreSortingPerformanceDayByIds" parameterType="String">
        delete from store_sorting_performance_day where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>