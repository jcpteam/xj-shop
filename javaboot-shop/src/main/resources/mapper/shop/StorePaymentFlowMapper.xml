<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StorePaymentFlowMapper">
    
    <resultMap type="StorePaymentFlow" id="StorePaymentFlowResult">
        <result property="id"    column="id"    />
        <result property="payOrderNo"    column="pay_order_no"    />
        <result property="receiptId"    column="receipt_id"    />
        <result property="orderIds"    column="order_ids"    />
        <result property="cmbOrderNo"    column="cmb_order_no"    />
        <result property="qrCode"    column="qr_code"    />
        <result property="status"    column="status"    />
        <result property="returnCode"    column="return_code"    />
        <result property="respCode"    column="resp_code"    />
        <result property="rspTxt"    column="rsp_txt"    />
        <result property="qryRspTxt"    column="qry_rsp_txt"    />
        <result property="tradeState"    column="trade_state"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStorePaymentFlowVo">
        select id, pay_order_no, receipt_id,  order_ids, cmb_order_no, qr_code, status, return_code, resp_code, rsp_txt, qry_rsp_txt,trade_state, create_time, last_modify_time from store_payment_flow
    </sql>

    <select id="selectStorePaymentFlowList" parameterType="StorePaymentFlow" resultMap="StorePaymentFlowResult">
        <include refid="selectStorePaymentFlowVo"/>
        <where>  
            <if test="payOrderNo != null  and payOrderNo != ''"> and pay_order_no = #{payOrderNo}</if>
            <if test="receiptId != null"> and receipt_id = #{receiptId}</if>
            <if test="orderIds != null  and orderIds != ''"> and order_ids = #{orderIds}</if>
            <if test="cmbOrderNo != null  and cmbOrderNo != ''"> and cmb_order_no = #{cmbOrderNo}</if>
            <if test="qrCode != null  and qrCode != ''"> and qr_code = #{qrCode}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="returnCode != null  and returnCode != ''"> and return_code = #{returnCode}</if>
            <if test="respCode != null  and respCode != ''"> and resp_code = #{respCode}</if>
            <if test="rspTxt != null  and rspTxt != ''"> and rsp_txt = #{rspTxt}</if>
            <if test="qryRspTxt != null  and qryRspTxt != ''"> and qry_rsp_txt = #{qryRspTxt}</if>
            <if test="tradeState != null  and tradeState != ''"> and trade_state = #{tradeState}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
        </where>
    </select>
    
    <select id="selectStorePaymentFlowById" parameterType="Long" resultMap="StorePaymentFlowResult">
        <include refid="selectStorePaymentFlowVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertStorePaymentFlow" parameterType="StorePaymentFlow" useGeneratedKeys="true" keyProperty="id">
        insert into store_payment_flow
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="payOrderNo != null  and payOrderNo != ''">pay_order_no,</if>
            <if test="orderIds != null  and orderIds != ''">order_ids,</if>
            <if test="receiptId != null ">receipt_id,</if>
            <if test="cmbOrderNo != null  and cmbOrderNo != ''">cmb_order_no,</if>
            <if test="qrCode != null  and qrCode != ''">qr_code,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="returnCode != null  and returnCode != ''">return_code,</if>
            <if test="respCode != null  and respCode != ''">resp_code,</if>
            <if test="rspTxt != null  and rspTxt != ''">rsp_txt,</if>
            <if test="tradeState != null  and tradeState != ''">trade_state,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="payOrderNo != null  and payOrderNo != ''">#{payOrderNo},</if>
            <if test="orderIds != null  and orderIds != ''">#{orderIds},</if>
            <if test="receiptId != null ">#{receiptId},</if>
            <if test="cmbOrderNo != null  and cmbOrderNo != ''">#{cmbOrderNo},</if>
            <if test="qrCode != null  and qrCode != ''">#{qrCode},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="returnCode != null  and returnCode != ''">#{returnCode},</if>
            <if test="respCode != null  and respCode != ''">#{respCode},</if>
            <if test="rspTxt != null  and rspTxt != ''">#{rspTxt},</if>
            <if test="tradeState != null  and tradeState != ''">#{tradeState},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStorePaymentFlow" parameterType="StorePaymentFlow">
        update store_payment_flow
        <trim prefix="SET" suffixOverrides=",">
            <if test="payOrderNo != null  and payOrderNo != ''">pay_order_no = #{payOrderNo},</if>
            <if test="orderIds != null  and orderIds != ''">order_ids = #{orderIds},</if>
            <if test="receiptId != null ">receipt_id = #{receiptId},</if>
            <if test="cmbOrderNo != null  and cmbOrderNo != ''">cmb_order_no = #{cmbOrderNo},</if>
            <if test="qrCode != null  and qrCode != ''">qr_code = #{qrCode},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="returnCode != null  and returnCode != ''">return_code = #{returnCode},</if>
            <if test="respCode != null  and respCode != ''">resp_code = #{respCode},</if>
            <if test="rspTxt != null  and rspTxt != ''">rsp_txt = #{rspTxt},</if>
            <if test="qryRspTxt != null  and qryRspTxt != ''">qry_rsp_txt = #{qryRspTxt},</if>
            <if test="tradeState != null  and tradeState != ''">trade_state = #{tradeState},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>


    <update id="updateStorePaymentFlowStatus" parameterType="StorePaymentFlow">
        update store_payment_flow set status = #{status}, qry_rsp_txt = #{qryRspTxt},last_modify_time = current_timestamp
        where pay_order_no = #{payOrderNo}
    </update>

    <delete id="deleteStorePaymentFlowById" parameterType="Long">
        delete from store_payment_flow where id = #{id}
    </delete>

    <delete id="deleteStorePaymentFlowByIds" parameterType="String">
        delete from store_payment_flow where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>