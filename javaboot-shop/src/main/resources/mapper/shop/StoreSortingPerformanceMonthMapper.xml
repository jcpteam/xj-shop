<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreSortingPerformanceMonthMapper">
    
    <resultMap type="StoreSortingPerformanceMonth" id="StoreSortingPerformanceMonthResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="userName"    column="user_name"    />
        <result property="deptId"    column="dept_id"    />
        <result property="deptName"    column="dept_name"    />
        <result property="sortingMonth"    column="sorting_month"    />
        <result property="result"    column="result"    />
        <result property="stockResult"    column="stock_result"    />
        <result property="adjustResult"    column="adjust_result"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreSortingPerformanceMonthVo">
        select sspm.id, sspm.user_id, sspm.dept_id, sspm.sorting_month, sspm.result,sspm.stock_result,sspm.adjust_result, sspm.operator_id, sspm.status, sspm.create_time, sspm.last_modify_time,
              d.dept_name,su.user_name,su1.user_name as operatorName
        from store_sorting_performance_month sspm
        left join sys_dept d on sspm.dept_id = d.dept_id
        left join sys_user su on sspm.user_id = su.user_id
        left join sys_user su1 on sspm.operator_id = su1.user_id
    </sql>

    <select id="selectStoreSortingPerformanceMonthList" parameterType="StoreSortingPerformanceMonth" resultMap="StoreSortingPerformanceMonthResult">
        <include refid="selectStoreSortingPerformanceMonthVo"/>
        <where>
            sspm.status != '0'
            <if test="userId != null "> and sspm.user_id = #{userId}</if>
            <if test="deptId != null  and deptId != ''"> and sspm.dept_id = #{deptId}</if>
            <if test="sortingMonth != null  and sortingMonth != ''"> and sspm.sorting_month = #{sortingMonth}</if>
            <if test="userName != null  and userName != ''"> and su.user_name like concat('%', #{userName}, '%')</if>
        </where>
    </select>
    
    <select id="selectStoreSortingPerformanceMonthById" parameterType="Long" resultMap="StoreSortingPerformanceMonthResult">
        <include refid="selectStoreSortingPerformanceMonthVo"/>
        where sspm.id = #{id}
    </select>
        
    <insert id="insertStoreSortingPerformanceMonth" parameterType="StoreSortingPerformanceMonth" useGeneratedKeys="true" keyProperty="id">
        insert into store_sorting_performance_month
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null ">user_id,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="sortingMonth != null  and sortingMonth != ''">sorting_month,</if>
            <if test="result != null ">result,</if>
            <if test="stockResult != null ">stock_result,</if>
            <if test="adjustResult != null ">adjust_result,</if>
            <if test="operatorId != null ">operator_id,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null ">#{userId},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="sortingMonth != null  and sortingMonth != ''">#{sortingMonth},</if>
            <if test="result != null ">#{result},</if>
            <if test="stockResult != null ">#{stockResult},</if>
            <if test="adjustResult != null ">#{adjustResult},</if>
            <if test="operatorId != null ">#{operatorId},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreSortingPerformanceMonth" parameterType="StoreSortingPerformanceMonth">
        update store_sorting_performance_month
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="sortingMonth != null  and sortingMonth != ''">sorting_month = #{sortingMonth},</if>
            <if test="result != null ">result = #{result},</if>
            <if test="stockResult != null ">stock_result = #{stockResult},</if>
            <if test="adjustResult != null ">adjust_result = #{adjustResult},</if>
            <if test="operatorId != null ">operator_id = #{operatorId},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStoreSortingPerformanceMonthById" parameterType="Long">
        delete from store_sorting_performance_month where id = #{id}
    </delete>

    <delete id="deleteStoreSortingPerformanceMonthByIds" parameterType="String">
        delete from store_sorting_performance_month where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>