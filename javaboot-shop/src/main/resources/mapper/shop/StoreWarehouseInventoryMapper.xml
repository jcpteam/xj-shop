<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreWarehouseInventoryMapper">

    <resultMap type="com.javaboot.shop.vo.StoreWarehouseInventoryVO" id="StoreWarehouseInventoryResult">
        <result property="inventoryId"    column="inventory_id"    />
        <result property="inventoryNo"    column="inventory_no"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="creatorId"    column="creator_id"    />
        <result property="quantity"    column="quantity"    />
        <result property="lonelyNumber"    column="lonely_number"    />
        <result property="amount"    column="amount"    />
        <result property="intentoryDate"    column="intentory_date"    />
        <result property="intentorySrcId"    column="intentory_src_id"    />
        <result property="status"    column="status"    />
        <result property="replaceFlag"    column="replace_flag"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreWarehouseInventoryVo">
        select inventory_id, inventory_no, warehouse_id, dept_id, creator_id, quantity,
        lonely_number, amount, intentory_date, intentory_src_id,status, replace_flag, create_time, last_modify_time
        from store_warehouse_inventory
    </sql>

    <select id="selectStoreWarehouseInventoryList" parameterType="StoreWarehouseInventory" resultMap="StoreWarehouseInventoryResult">
        <include refid="selectStoreWarehouseInventoryVo"/>
        <where>
            status != '0'
            <if test="inventoryNo != null  and inventoryNo != ''"> and inventory_no = #{inventoryNo}</if>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="deptId != null  and deptId != ''"> and dept_id = #{deptId}</if>
            <if test="creatorId != null "> and creator_id = #{creatorId}</if>
            <if test="quantity != null "> and quantity = #{quantity}</if>
            <if test="lonelyNumber != null "> and lonely_number = #{lonelyNumber}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="intentoryDate != null "> and intentory_date = #{intentoryDate}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="lastModifyTime != null "> and last_modify_time = #{lastModifyTime}</if>
            <if test="startTime != null and startTime!='' and endTime != null and endTime!='' ">
                and intentory_date  BETWEEN
                DATE_FORMAT(#{startTime},'%Y-%m-%d %H:%i:%s')
                AND DATE_FORMAT(#{endTime},'%Y-%m-%d %H:%i:%s')
            </if>
        </where>
    </select>
    <select id="selectLastStoreWarehouseInventoryByWarehouseId"  resultMap="StoreWarehouseInventoryResult">
        <include refid="selectStoreWarehouseInventoryVo"/>
        <where>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="intentoryDate != null "> and intentory_date &lt; #{intentoryDate}</if>
        </where>
        and status = '1'
        ORDER BY intentory_date DESC LIMIT 1
    </select>
    <select id="selectStoreWarehouseInventoryById" parameterType="Long" resultMap="StoreWarehouseInventoryResult">
        <include refid="selectStoreWarehouseInventoryVo"/>
        where inventory_id = #{inventoryId}
    </select>

    <insert id="insertStoreWarehouseInventory" parameterType="StoreWarehouseInventory" useGeneratedKeys="true" keyProperty="inventoryId">
        insert into store_warehouse_inventory
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="inventoryNo != null  and inventoryNo != ''">inventory_no,</if>
            <if test="warehouseId != null ">warehouse_id,</if>
            <if test="deptId != null  and deptId != ''">dept_id,</if>
            <if test="creatorId != null ">creator_id,</if>
            <if test="quantity != null ">quantity,</if>
            <if test="lonelyNumber != null ">lonely_number,</if>
            <if test="amount != null ">amount,</if>
            <if test="intentoryDate != null ">intentory_date,</if>
            <if test="intentorySrcId != null ">intentory_src_id,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="replaceFlag != null  and replaceFlag != ''">replace_flag,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="inventoryNo != null  and inventoryNo != ''">#{inventoryNo},</if>
            <if test="warehouseId != null ">#{warehouseId},</if>
            <if test="deptId != null  and deptId != ''">#{deptId},</if>
            <if test="creatorId != null ">#{creatorId},</if>
            <if test="quantity != null ">#{quantity},</if>
            <if test="lonelyNumber != null ">#{lonelyNumber},</if>
            <if test="amount != null ">#{amount},</if>
            <if test="intentoryDate != null ">#{intentoryDate},</if>
            <if test="intentorySrcId != null ">#{intentorySrcId},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="replaceFlag != null  and replaceFlag != ''">#{replaceFlag},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
        </trim>
    </insert>

    <update id="updateStoreWarehouseInventory" parameterType="StoreWarehouseInventory">
        update store_warehouse_inventory
        <trim prefix="SET" suffixOverrides=",">
            <if test="inventoryNo != null  and inventoryNo != ''">inventory_no = #{inventoryNo},</if>
            <if test="warehouseId != null ">warehouse_id = #{warehouseId},</if>
            <if test="deptId != null  and deptId != ''">dept_id = #{deptId},</if>
            <if test="creatorId != null ">creator_id = #{creatorId},</if>
            <if test="quantity != null ">quantity = #{quantity},</if>
            <if test="lonelyNumber != null ">lonely_number = #{lonelyNumber},</if>
            <if test="amount != null ">amount = #{amount},</if>
            <if test="intentoryDate != null ">intentory_date = #{intentoryDate},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="replaceFlag != null  and replaceFlag != ''">replace_flag = #{replaceFlag},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where inventory_id = #{inventoryId}
    </update>

    <update id="deleteStoreWarehouseInventoryById" parameterType="Long">
        update store_warehouse_inventory set status=0,last_modify_time = now() where inventory_id = #{inventoryId}
    </update>

    <update id="deleteStoreWarehouseInventoryByIds" parameterType="String">
        update store_warehouse_inventory set status=0,last_modify_time = now() where inventory_id in
        <foreach item="inventoryId" collection="array" open="(" separator="," close=")">
            #{inventoryId}
        </foreach>
    </update>

</mapper>