<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaboot.shop.mapper.StoreSortingBoxMapper">
    
    <resultMap type="StoreSortingBox" id="StoreSortingBoxResult">
        <result property="id"    column="id"    />
        <result property="boxName"    column="box_name"    />
        <result property="boxWeight"    column="box_weight"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="lastModifyTime"    column="last_modify_time"    />
    </resultMap>

    <sql id="selectStoreSortingBoxVo">
        select id, box_name, box_weight, status, create_time, last_modify_time from store_sorting_box
    </sql>

    <select id="selectStoreSortingBoxList" parameterType="StoreSortingBox" resultMap="StoreSortingBoxResult">
        <include refid="selectStoreSortingBoxVo"/>
        <where>  
            <if test="boxName != null  and boxName != ''"> and box_name like concat('%', #{boxName}, '%')</if>
        </where>
    </select>
    
    <select id="selectStoreSortingBoxById" parameterType="Long" resultMap="StoreSortingBoxResult">
        <include refid="selectStoreSortingBoxVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertStoreSortingBox" parameterType="StoreSortingBox" useGeneratedKeys="true" keyProperty="id">
        insert into store_sorting_box
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="boxName != null  and boxName != ''">box_name,</if>
            <if test="boxWeight != null ">box_weight,</if>
            <if test="status != null  and status != ''">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="lastModifyTime != null ">last_modify_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="boxName != null  and boxName != ''">#{boxName},</if>
            <if test="boxWeight != null ">#{boxWeight},</if>
            <if test="status != null  and status != ''">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="lastModifyTime != null ">#{lastModifyTime},</if>
         </trim>
    </insert>

    <update id="updateStoreSortingBox" parameterType="StoreSortingBox">
        update store_sorting_box
        <trim prefix="SET" suffixOverrides=",">
            <if test="boxName != null  and boxName != ''">box_name = #{boxName},</if>
            <if test="boxWeight != null ">box_weight = #{boxWeight},</if>
            <if test="status != null  and status != ''">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="lastModifyTime != null ">last_modify_time = #{lastModifyTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStoreSortingBoxById" parameterType="Long">
        delete from store_sorting_box where id = #{id}
    </delete>

    <delete id="deleteStoreSortingBoxByIds" parameterType="String">
        delete from store_sorting_box where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>